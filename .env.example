PORT=8787
VITE_API_BASE_URL=http://localhost:8787

# 通用 OpenAI 兼容 API。只放后端，不要写进前端。
AI_API_KEY=
AI_BASE_URL=https://api.siliconflow.cn/v1
AI_MODEL=deepseek-ai/DeepSeek-V4-Flash
AI_PROVIDER_LABEL=硅基流动

# DeepSeek 官方 OpenAI 兼容接口，Key 只放后端环境变量
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 阿里云百炼/千问 OpenAI 兼容接口
# 北京或新加坡通常需要替换 WorkspaceId：
# https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# 美国弗吉尼亚可用：https://dashscope-us.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=

# 知识库检索命中分数。越高越严格，越低越容易命中。
KNOWLEDGE_MIN_SCORE=3
