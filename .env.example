PORT=8787
VITE_API_BASE_URL=http://localhost:8787

# 通用 OpenAI 兼容 API。只放后端，不要写进前端。
AI_API_KEY=
AI_BASE_URL=https://api.siliconflow.cn/v1
AI_MODEL=deepseek-ai/DeepSeek-V4-Flash
AI_PROVIDER_LABEL=硅基流动

# DeepSeek 官方 OpenAI 兼容接口，Key 只放后端环境变量。
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 阿里云百炼/千问 OpenAI 兼容接口。
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=

# 千问视觉/多模态模型，用于图片识别和视频抽帧分析。
QWEN_VL_API_KEY=
# 如果使用硅基流动，也可以改用 SILICONFLOW_API_KEY；代码会兼容这两个变量和旧的 DASHSCOPE_API_KEY。
SILICONFLOW_API_KEY=
QWEN_VL_MODEL=Qwen/Qwen3.6-35B-A3B
QWEN_VL_BASE_URL=https://api.siliconflow.cn/v1

# 知识库检索命中分数。代码会强制不低于 10，避免低相关资料误命中。
KNOWLEDGE_MIN_SCORE=10
