    "AI_PROVIDER_LABEL": "API 模型",
    "KNOWLEDGE_MIN_SCORE": "3"
  },
  "kv_namespaces": [
    {
      "binding": "MAIYA_KV",
      "id": "195808c30e2c453aaea2f61536839d30"
    }
  ]
}
